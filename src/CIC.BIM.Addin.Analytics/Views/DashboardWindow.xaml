<Window x:Class="CIC.BIM.Addin.Analytics.Views.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📊 Bảng điều khiển Hiệu suất — CIC BIM" 
        Width="960" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        Foreground="#CDD6F4">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="6"/>
        </Style>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#89B4FA"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#F5E0DC"/>
        </Style>
        <Style x:Key="MetricLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#6C7086"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with DatePicker -->
        <DockPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="📊 Bảng điều khiển Hiệu suất" FontSize="22" FontWeight="Bold" 
                       Foreground="#CDD6F4" VerticalAlignment="Center"/>
            <TextBlock Text=" — " FontSize="16" Foreground="#6C7086" VerticalAlignment="Center"/>
            <TextBlock x:Name="DateLabel" FontSize="16" Foreground="#A6ADC8" VerticalAlignment="Center"/>
            
            <!-- Right side: User + DatePicker -->
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="#45475A" CornerRadius="4" Padding="8,4" Margin="0,0,8,0" VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabel" FontSize="11" Foreground="#BAC2DE"/>
                </Border>
                <TextBlock Text="📅" FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker x:Name="DatePickerControl" Width="120" VerticalAlignment="Center"
                            SelectedDateChanged="DatePickerControl_SelectedDateChanged"/>
            </StackPanel>
        </DockPanel>

        <!-- KPI Cards Row 1: Thời gian -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,2">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="⏱ Tổng thời gian" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="TotalActiveText" Style="{StaticResource MetricValue}" Text="0 giờ"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="🏗 Dựng mô hình" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="ModelingText" Style="{StaticResource MetricValue}" Text="0 phút" Foreground="#A6E3A1"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="✏️ Chỉnh sửa" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="EditingText" Style="{StaticResource MetricValue}" Text="0 phút" Foreground="#89B4FA"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="📄 Xuất bản vẽ" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="DocumentingText" Style="{StaticResource MetricValue}" Text="0 phút" Foreground="#CBA6F7"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="🔗 Phối hợp" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="CoordinatingText" Style="{StaticResource MetricValue}" Text="0 phút" Foreground="#94E2D5"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- KPI Cards Row 2: Hiệu suất + Năng suất -->
        <UniformGrid Grid.Row="2" Columns="5" Margin="0,0,0,2">
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="😴 Chờ / Nghỉ" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="IdleText" Style="{StaticResource MetricValue}" Text="0 phút" Foreground="#F38BA8"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="⏳ Chờ hộp thoại" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="DialogWaitText" Style="{StaticResource MetricValue}" Text="0 phút" Foreground="#6C7086"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="📁 Phiên làm việc" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="SessionsText" Style="{StaticResource MetricValue}" Text="0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="🎯 Hiệu suất" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="EfficiencyText" Style="{StaticResource MetricValue}" Text="--" Foreground="#F9E2AF"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="⚡ Năng suất (phần tử/giờ)" Style="{StaticResource MetricLabel}"/>
                    <TextBlock x:Name="EPRText" Style="{StaticResource MetricValue}" Text="--" Foreground="#FAB387"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Element Stats Row -->
        <UniformGrid Grid.Row="3" Columns="3" Margin="0,0,0,4">
            <Border Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock Text="🆕 Tạo mới" FontSize="12" Foreground="#A6E3A1" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ElementsCreatedText" Text="0" FontSize="20" FontWeight="Bold"
                               Foreground="#A6E3A1" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock Text="✏️ Chỉnh sửa" FontSize="12" Foreground="#89B4FA" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ElementsModifiedText" Text="0" FontSize="20" FontWeight="Bold"
                               Foreground="#89B4FA" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock Text="🗑 Xóa bỏ" FontSize="12" Foreground="#F38BA8" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ElementsDeletedText" Text="0" FontSize="20" FontWeight="Bold"
                               Foreground="#F38BA8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>
        </UniformGrid>

        <!-- Charts Area -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Activity Distribution -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="📊 Phân bổ hoạt động" Style="{StaticResource HeaderStyle}"/>
                    <StackPanel x:Name="ActivityBarsPanel" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Weekly trend -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="📈 Xu hướng trong tuần" Style="{StaticResource HeaderStyle}"/>
                    <Canvas x:Name="WeeklyChartCanvas" Height="260" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer: Phát hiện & Nhận xét -->
        <Border Grid.Row="5" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="💡 Phát hiện &amp; Nhận xét" Style="{StaticResource HeaderStyle}"/>
                <TextBlock x:Name="WarningsText" TextWrapping="Wrap" FontSize="12" Foreground="#F9E2AF"
                           Text="Đang phân tích dữ liệu..."/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
