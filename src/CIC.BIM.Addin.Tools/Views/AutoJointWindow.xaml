<Window x:Class="CIC.BIM.Addin.Tools.Views.AutoJointWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔗 Tự động nối cấu kiện"
        Width="680" Height="620" MinWidth="580" MinHeight="550"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#CDD6F4">

    <Window.Resources>
        <ResourceDictionary Source="../Themes/ToolStyles.xaml"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="🔗 Tự động nối cấu kiện" FontSize="18" FontWeight="Bold"/>
            <TextBlock Text="Nối hình học tự động và thiết lập thứ tự ưu tiên cho các cấu kiện giao nhau"
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
            <Border Height="2" Background="{StaticResource BlueBrush}" Margin="0,8,0,0" Opacity="0.4"/>
        </StackPanel>

        <!-- ═══ QUY TẮC ƯU TIÊN ═══ -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header quy tắc -->
                <DockPanel Grid.Row="0" Background="#233A5C" Margin="0">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,4,0">
                        <Button x:Name="BtnAddRule" Content="＋" FontSize="14" FontWeight="Bold"
                                Width="28" Height="28" Margin="2"
                                Background="Transparent" Foreground="{StaticResource BlueBrush}"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="Thêm quy tắc mới" Click="BtnAddRule_Click"/>
                        <Button x:Name="BtnResetRules" Content="↺" FontSize="14"
                                Width="28" Height="28" Margin="2"
                                Background="Transparent" Foreground="{StaticResource TextMutedBrush}"
                                BorderThickness="0" Cursor="Hand"
                                ToolTip="Khôi phục quy tắc mặc định" Click="BtnResetRules_Click"/>
                    </StackPanel>
                    <Grid Margin="12,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Đối tượng cắt (ưu tiên)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#89B4FA" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="↔" FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Grid.Column="2" Text="Đối tượng bị cắt" FontSize="11" FontWeight="SemiBold"
                                   Foreground="#F9E2AF" HorizontalAlignment="Center"/>
                    </Grid>
                </DockPanel>

                <!-- Danh sách quy tắc (scrollable) -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,2,0,0">
                    <StackPanel x:Name="PanelRules" Margin="4"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══ PHẠM VI ÁP DỤNG ═══ -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12" Margin="0,8,0,0">
            <StackPanel>
                <TextBlock Text="Phạm vi áp dụng" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource BlueBrush}" Margin="0,0,0,6"/>
                <WrapPanel>
                    <RadioButton x:Name="RdCurrentView" Content="View hiện tại" IsChecked="True"
                                 Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,20,4"
                                 GroupName="Scope"/>
                    <RadioButton x:Name="RdEntireProject" Content="Toàn bộ dự án"
                                 Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,20,4"
                                 GroupName="Scope"/>
                    <RadioButton x:Name="RdSelected" Content="Đối tượng đã chọn"
                                 Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,20,4"
                                 GroupName="Scope"/>
                    <RadioButton x:Name="RdPickRegion" Content="Quét chọn vùng"
                                 Foreground="{StaticResource TextBrush}" FontSize="12" Margin="0,0,0,4"
                                 GroupName="Scope"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- ═══ PROGRESS ═══ -->
        <StackPanel Grid.Row="3" Margin="0,8,0,0">
            <ProgressBar x:Name="ProgressBar" Height="4" Minimum="0" Maximum="100" Value="0"
                         Background="#313244" Foreground="{StaticResource BlueBrush}"
                         BorderThickness="0"/>
            <TextBlock x:Name="TxtStatus" Text="Sẵn sàng. Thiết lập quy tắc và nhấn nút bên dưới."
                       FontSize="11" Foreground="{StaticResource TextSecBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ═══ BUTTONS ═══ -->
        <DockPanel Grid.Row="4" Margin="0,12,0,0">
            <Button x:Name="BtnClose" Content="Đóng" Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Right" Click="BtnClose_Click" Margin="8,0,0,0"/>
            <Button x:Name="BtnJoin" Content="🔗 Join / Switch Join" Style="{StaticResource PrimaryButton}"
                    DockPanel.Dock="Right" Click="BtnJoin_Click" Margin="8,0,0,0" Padding="16,8"/>
            <Button x:Name="BtnUnjoin" Content="✂ UnJoin" Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Left" Click="BtnUnjoin_Click" Padding="16,8"/>
        </DockPanel>
    </Grid>
</Window>
