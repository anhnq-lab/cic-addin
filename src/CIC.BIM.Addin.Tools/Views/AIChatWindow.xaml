<Window x:Class="CIC.BIM.Addin.Tools.Views.AIChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🤖 CIC AI Assistant — Hỏi đáp Mô hình BIM"
        Width="520" Height="680"
        MinWidth="400" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary Source="/CIC.BIM.Addin.Tools;component/Themes/ToolStyles.xaml"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- Status bar -->
            <RowDefinition Height="Auto"/>
            <!-- Chat messages -->
            <RowDefinition Height="*"/>
            <!-- Input area -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Border Grid.Row="0" Background="#313244" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="🤖 CIC AI Assistant" FontSize="16" FontWeight="Bold"
                               Foreground="#CDD6F4"/>
                    <TextBlock x:Name="txtProjectName" Text="Đang tải mô hình..."
                               FontSize="11" Foreground="#A6ADC8" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Refresh button -->
                    <Button x:Name="btnRefresh" Content="🔄" ToolTip="Tải lại dữ liệu model"
                            Width="32" Height="32" FontSize="14"
                            Background="#45475A" Foreground="#CDD6F4" BorderThickness="0"
                            Cursor="Hand" Click="BtnRefresh_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Settings button -->
                    <Button x:Name="btnSettings" Content="⚙️" ToolTip="Cài đặt API Key"
                            Width="32" Height="32" FontSize="14" Margin="6,0,0,0"
                            Background="#45475A" Foreground="#CDD6F4" BorderThickness="0"
                            Cursor="Hand" Click="BtnSettings_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Clear button -->
                    <Button x:Name="btnClear" Content="🗑️" ToolTip="Xóa lịch sử chat"
                            Width="32" Height="32" FontSize="14" Margin="6,0,0,0"
                            Background="#45475A" Foreground="#CDD6F4" BorderThickness="0"
                            Cursor="Hand" Click="BtnClear_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                        Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="1" Background="#181825" Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="statusDot" Width="8" Height="8" Fill="#A6E3A1"
                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="txtStatus" Text="Sẵn sàng"
                           FontSize="11" Foreground="#6C7086"/>
            </StackPanel>
        </Border>

        <!-- ═══ CHAT MESSAGES ═══ -->
        <ScrollViewer Grid.Row="2" x:Name="chatScroller"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#1E1E2E" Padding="12,8">
            <StackPanel x:Name="chatPanel" Margin="0,0,0,8">
                <!-- Welcome message -->
                <Border Background="#313244" CornerRadius="12" Padding="14,10" Margin="0,4,40,4"
                        HorizontalAlignment="Left" MaxWidth="400">
                    <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#CDD6F4">
                        <Run FontWeight="SemiBold" Foreground="#89B4FA">🤖 AI Assistant</Run>
                        <LineBreak/>
                        <Run>Xin chào! Tôi có thể giúp bạn hỏi đáp về mô hình BIM.</Run>
                        <LineBreak/><LineBreak/>
                        <Run Foreground="#A6ADC8" FontSize="11.5">Ví dụ:</Run>
                        <LineBreak/>
                        <Run Foreground="#A6ADC8" FontSize="11.5">• "Có bao nhiêu cột ở tầng 2?"</Run>
                        <LineBreak/>
                        <Run Foreground="#A6ADC8" FontSize="11.5">• "Tổng thể tích bê tông là bao nhiêu?"</Run>
                        <LineBreak/>
                        <Run Foreground="#A6ADC8" FontSize="11.5">• "Liệt kê phòng tầng 3"</Run>
                    </TextBlock>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- ═══ INPUT AREA ═══ -->
        <Border Grid.Row="3" Background="#313244" Padding="12" BorderBrush="#45475A"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtInput" Grid.Column="0"
                         Background="#45475A" Foreground="#CDD6F4"
                         BorderBrush="#585B70" BorderThickness="1"
                         FontSize="13" Padding="10,8"
                         CaretBrush="#CDD6F4"
                         AcceptsReturn="False"
                         MaxLength="2000"
                         KeyDown="TxtInput_KeyDown">
                    <TextBox.Template>
                        <ControlTemplate TargetType="TextBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                            </Border>
                        </ControlTemplate>
                    </TextBox.Template>
                </TextBox>

                <Button x:Name="btnSend" Grid.Column="1" Content="➤"
                        Width="40" Height="36" FontSize="16" Margin="8,0,0,0"
                        Background="#89B4FA" Foreground="#1E1E2E"
                        FontWeight="Bold" BorderThickness="0"
                        Cursor="Hand" Click="BtnSend_Click"
                        IsEnabled="True">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                    Padding="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
