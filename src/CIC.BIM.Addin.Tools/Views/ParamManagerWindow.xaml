<Window x:Class="CIC.BIM.Addin.Tools.Views.ParamManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📋 Quản lý Tham số"
        Width="1100" Height="760" MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#CDD6F4">

    <Window.Resources>
        <ResourceDictionary Source="../Themes/ToolStyles.xaml"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <DockPanel>
                <Border x:Name="BadgeDiscipline" Style="{StaticResource DeptBadge}" Background="#233A5C" DockPanel.Dock="Right">
                    <TextBlock x:Name="TxtBadge" Text="Tất cả bộ môn" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BlueBrush}"/>
                </Border>
                <TextBlock Text="📋 Quản lý Tham số" FontSize="18" FontWeight="Bold"/>
            </DockPanel>
            <TextBlock Text="Quản lý dữ liệu và thông tin cho tất cả đối tượng trong mô hình BIM"
                       FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
            <Border Height="2" Background="{StaticResource BlueBrush}" Margin="0,10,0,0" Opacity="0.4"/>
        </StackPanel>

        <!-- ═══ FILTER BAR — BỘ MÔN + CẤU KIỆN ═══ -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Dòng 1: Bộ môn + Nút Tải -->
                <DockPanel Grid.Row="0">
                    <Button x:Name="BtnLoad" Content="▶ Tải dữ liệu" Style="{StaticResource PrimaryButton}"
                            DockPanel.Dock="Right" Click="BtnLoad_Click" Margin="12,0,0,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Bộ môn:" FontSize="12" Foreground="{StaticResource TextSecBrush}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <ComboBox x:Name="CboDiscipline" Width="140" FontSize="12"
                                  Style="{StaticResource DarkComboBox}"
                                  SelectionChanged="CboDiscipline_SelectionChanged"/>
                    </StackPanel>
                </DockPanel>

                <!-- Dòng 2: Checkbox cấu kiện (dynamic) -->
                <WrapPanel x:Name="PanelCategories" Grid.Row="1" Margin="0,8,0,0"/>
            </Grid>
        </Border>

        <!-- ═══ SEARCH BAR ═══ -->
        <Border Grid.Row="2" Background="#313244" CornerRadius="6" Padding="8,6" Margin="0,6,0,0">
            <DockPanel>
                <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="TxtSearch" Style="{StaticResource DarkTextBox}"
                         FontSize="12" Background="Transparent" BorderThickness="0"
                         TextChanged="TxtSearch_TextChanged">
                    <TextBox.Tag>Tìm kiếm nhanh (theo tên, type, tầng...)</TextBox.Tag>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- ═══ DATAGRID ═══ -->
        <DataGrid x:Name="DgParams" Grid.Row="3" Margin="0,8,0,0"
                  AutoGenerateColumns="True" CanUserAddRows="False"
                  CanUserSortColumns="True" CanUserReorderColumns="True"
                  Background="#313244" Foreground="#CDD6F4"
                  GridLinesVisibility="All" HorizontalGridLinesBrush="#45475A" VerticalGridLinesBrush="#3B3D50"
                  BorderBrush="#45475A" BorderThickness="1"
                  RowBackground="#313244" AlternatingRowBackground="#3B3D50"
                  SelectionMode="Extended" SelectionUnit="FullRow"
                  HeadersVisibility="Column" ColumnHeaderHeight="32"
                  AutoGeneratingColumn="DgParams_AutoGeneratingColumn">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#233A5C"/>
                    <Setter Property="Foreground" Value="#89B4FA"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="BorderBrush" Value="#45475A"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Foreground" Value="#CDD6F4"/>
                    <Setter Property="FontSize" Value="11"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#45475A"/>
                            <Setter Property="Foreground" Value="#A6E3A1"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#45475A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- ═══ STATUS + BATCH ═══ -->
        <Border Grid.Row="4" Background="#1E1E2E" Padding="8" Margin="0,8,0,0" CornerRadius="6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBlock Text="Tham số:" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtBatchParam" Width="120" Style="{StaticResource DarkTextBox}" FontSize="11"/>
                    <TextBlock Text="=" FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" Margin="6,0"/>
                    <TextBox x:Name="TxtBatchValue" Width="120" Style="{StaticResource DarkTextBox}" FontSize="11"/>
                    <Button x:Name="BtnBatch" Content="📝 Gán hàng loạt" Style="{StaticResource SecondaryButton}"
                            Click="BtnBatch_Click" Margin="8,0,0,0" Padding="12,6" FontSize="11"/>
                </StackPanel>
                <TextBlock x:Name="TxtStatus" FontSize="11.5" Foreground="{StaticResource TextSecBrush}"
                           VerticalAlignment="Center" Text="Chưa tải dữ liệu. Chọn bộ môn và nhấn Tải dữ liệu."/>
            </DockPanel>
        </Border>

        <!-- ═══ FOOTER ═══ -->
        <DockPanel Grid.Row="5" Margin="0,12,0,0">
            <Button x:Name="BtnCancel" Content="Đóng" Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Right" Click="BtnCancel_Click" Margin="8,0,0,0"/>
            <Button x:Name="BtnWrite" Content="💾 Ghi vào Mô hình" Style="{StaticResource PrimaryButton}"
                    DockPanel.Dock="Right" Click="BtnWrite_Click" IsEnabled="False" Margin="8,0,0,0"/>
            <Button x:Name="BtnExport" Content="📊 Xuất Excel" Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Right" Click="BtnExport_Click" IsEnabled="False" Margin="8,0,0,0"/>
            <Button x:Name="BtnAutoFill" Content="🔄 Tự động điền" Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Left" Click="BtnAutoFill_Click" IsEnabled="False"/>
        </DockPanel>
    </Grid>
</Window>
