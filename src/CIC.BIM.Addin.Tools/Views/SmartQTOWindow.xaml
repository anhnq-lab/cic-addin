<Window x:Class="CIC.BIM.Addin.Tools.Views.SmartQTOWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Khối Lượng Tự Động (Smart QTO)"
        Width="1000" Height="680" MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#CDD6F4" FontSize="13">

    <Window.Resources>
        <!-- Load dark theme resources -->
        <ResourceDictionary Source="../Themes/ToolStyles.xaml"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,15">
            <Border Style="{StaticResource DeptBadge}" Background="#233A5C" DockPanel.Dock="Right">
                <TextBlock Text="BOQ — Quantity" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource BlueBrush}"/>
            </Border>
            <TextBlock Text="📊 Bóc Tách Khối Lượng Tự Động" FontSize="18" FontWeight="Bold" Foreground="#89B4FA"/>
        </DockPanel>

        <!-- Main Content (2 Columns) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: SETTINGS -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Scope & Options -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="① PHẠM VI BÓC TÁCH" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,12">
                            <RadioButton x:Name="radEntireProject" Content="Toàn bộ dự án" IsChecked="True" Foreground="#CDD6F4" Margin="0,0,0,6"/>
                            <RadioButton x:Name="radActiveSelection" Content="Chỉ các đối tượng đang chọn (Selection)" Foreground="#CDD6F4"/>
                        </StackPanel>
                        
                        <TextBlock Text="TÙY CHỌN MỞ RỘNG" Style="{StaticResource SectionHeader}" Margin="0,8,0,8"/>
                        <CheckBox x:Name="chkGroupByLevel" Content="Phân nhóm dữ liệu theo Tầng (Level)" Style="{StaticResource DarkCheckBox}" IsChecked="True"/>
                    </StackPanel>
                </Border>

                <!-- Categories -->
                <Border Grid.Row="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="② CHỌN HẠNG MỤC CẦN BÓC" Style="{StaticResource SectionHeader}" Margin="0,0,0,8"/>
                        
                        <ListBox x:Name="lstCategories" Grid.Row="1" ScrollViewer.VerticalScrollBarVisibility="Auto" Background="#1E1E2E" BorderThickness="0">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#CDD6F4"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#3B3D50"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#313244"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="5,0,0,0" Style="{StaticResource DarkCheckBox}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <!-- RIGHT COLUMN: PREVIEW DATAGRID -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="③ BẢN XEM TRƯỚC DỮ LIỆU (PREVIEW)" Style="{StaticResource SectionHeader}" Margin="12,12,12,8"/>
                    
                    <!-- DgResults inherits colors from FormworkWindow.xaml data grid styling -->
                    <DataGrid x:Name="dgPreview" Grid.Row="1" AutoGenerateColumns="False" 
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                              Background="#313244" Foreground="#CDD6F4"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#45475A"
                              RowBackground="#313244" AlternatingRowBackground="#3B3D50"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              RowHeight="30" ColumnHeaderHeight="35" BorderThickness="0,1,0,0" BorderBrush="#45475A">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#233A5C"/>
                                <Setter Property="Foreground" Value="#89B4FA"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,4"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                <Setter Property="BorderBrush" Value="#45475A"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                                <Setter Property="Padding" Value="6,3"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                                            <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#45475A"/>
                                        <Setter Property="Foreground" Value="#CDD6F4"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.GroupStyle>
                            <!-- Nhóm Tầng -->
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="True" BorderThickness="0,0,0,1" BorderBrush="#1E1E2E">
                                                        <Expander.Header>
                                                            <StackPanel Orientation="Horizontal" Margin="5,8,5,8">
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#89B4FA" FontSize="14"/>
                                                                <TextBlock Text="{Binding ItemCount, StringFormat=' ({0} cấu kiện)'}" Foreground="#7F849C" Margin="10,0,0,0" FontStyle="Italic"/>
                                                            </StackPanel>
                                                        </Expander.Header>
                                                        <ItemsPresenter />
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                            
                            <!-- Nhóm Hạng mục -->
                            <GroupStyle>
                                <GroupStyle.ContainerStyle>
                                    <Style TargetType="{x:Type GroupItem}">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="{x:Type GroupItem}">
                                                    <Expander IsExpanded="True" Background="#1E1E2E">
                                                        <Expander.Header>
                                                            <StackPanel Orientation="Horizontal" Margin="25,4,5,4">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="#A6E3A1" FontSize="13"/>
                                                            </StackPanel>
                                                        </Expander.Header>
                                                        <ItemsPresenter />
                                                    </Expander>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </GroupStyle.ContainerStyle>
                            </GroupStyle>
                        </DataGrid.GroupStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tầng" Binding="{Binding LevelName}" Width="100"/>
                            <DataGridTextColumn Header="Hạng mục" Binding="{Binding CategoryName}" Width="110"/>
                            <DataGridTextColumn Header="Family &amp; Type" Binding="{Binding FamilyAndType}" Width="*"/>
                            <DataGridTextColumn Header="Size/Dày" Binding="{Binding SizeTag}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FAB387"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="SL" Binding="{Binding Count}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Chiều dài(m)" Binding="{Binding LengthM, StringFormat={}{0:0.##}}" Width="85">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Diện tích(m2)" Binding="{Binding AreaM2, StringFormat={}{0:0.##}}" Width="95">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Thể tích(m3)" Binding="{Binding VolumeM3, StringFormat={}{0:0.##}}" Width="95">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="Foreground" Value="#A6E3A1"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <!-- Summary info -->
                    <Border Grid.Row="2" Background="#1E1E2E" Padding="12,8" CornerRadius="0,0,8,8">
                        <DockPanel>
                            <TextBlock x:Name="txtSummary" Text="Bấm 'Tính Toán' để bắt đầu..." FontSize="12" Foreground="{StaticResource TextSecBrush}"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Actions -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock x:Name="txtStatus" Grid.Column="0" VerticalAlignment="Center" Foreground="{StaticResource TextSecBrush}" Text=""/>
            
            <Button x:Name="btnCancel" Grid.Column="1" Content="Đóng" Style="{StaticResource SecondaryButton}" 
                    Width="80" Click="BtnCancel_Click" Margin="0,0,10,0"/>

            <Button x:Name="btnExport" Grid.Column="2" Content="📄 Xuất BOQ Excel" Style="{StaticResource SecondaryButton}" 
                    Width="140" Click="BtnExport_Click" IsEnabled="False" Margin="0,0,10,0"/>
            
            <Button x:Name="btnCalculate" Grid.Column="3" Content="▶ Tính Toán Khối Lượng" Style="{StaticResource PrimaryButton}" 
                    Width="180" Click="BtnCalculate_Click"/>
        </Grid>
    </Grid>
</Window>
