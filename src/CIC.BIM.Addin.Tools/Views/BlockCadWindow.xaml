<Window x:Class="CIC.BIM.Addin.Tools.Views.BlockCadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📦 Đặt thiết bị theo Block CAD — B1.23"
        Width="680" Height="640" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E" Foreground="#CDD6F4">

    <Window.Resources>
        <ResourceDictionary Source="../Themes/ToolStyles.xaml"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <DockPanel>
                <Border Style="{StaticResource DeptBadge}" Background="#3D2E1A" DockPanel.Dock="Right">
                    <TextBlock Text="MEP — Cơ điện" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource AmberBrush}"/>
                </Border>
                <TextBlock Text="📦 Đặt thiết bị theo Block CAD" FontSize="18" FontWeight="Bold"/>
            </DockPanel>
            <TextBlock Text="B1.23 — Block CAD → Equipment (Dynamic Block)" FontSize="11"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
            <Border Height="2" Background="{StaticResource AmberBrush}" Margin="0,10,0,0" Opacity="0.4"/>
        </StackPanel>

        <!-- ═══ CONTENT ═══ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card}" Grid.Row="0">
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecBrush}"
                           Text="Đọc Block CAD (bao gồm Dynamic Block) → tự đặt Family Revit tại đúng vị trí và góc xoay. Thiết lập mapping Block → Family bên dưới."/>
            </Border>

            <!-- Filter -->
            <Border Style="{StaticResource Card}" Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                        <TextBlock Text="Layer CAD" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtLayer" Text="*" Style="{StaticResource DarkTextBox}"
                                 ToolTip="Layer name hoặc * cho tất cả"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                        <TextBlock Text="Cao độ mặc định (mm)" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="TxtDefaultElevation" Text="0" Style="{StaticResource DarkTextBox}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <CheckBox x:Name="ChkDynamicBlock" Content="Dynamic Block"
                                  Style="{StaticResource DarkCheckBox}" IsChecked="True"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Mapping DataGrid -->
            <Border Style="{StaticResource Card}" Grid.Row="2">
                <DockPanel>
                    <TextBlock Text="MAPPING: BLOCK CAD → FAMILY REVIT" Style="{StaticResource SectionHeader}"
                               DockPanel.Dock="Top"/>
                    <DataGrid x:Name="MappingGrid" AutoGenerateColumns="False"
                              Background="#313244" Foreground="#CDD6F4"
                              RowBackground="#313244" AlternatingRowBackground="#3B3D50"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#45475A"
                              BorderThickness="0" CanUserAddRows="True"
                              HeadersVisibility="Column" FontSize="12">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#45475A"/>
                                <Setter Property="Foreground" Value="#A6ADC8"/>
                                <Setter Property="Padding" Value="8,6"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="11"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Block Name (CAD)" Binding="{Binding BlockName}" Width="*"/>
                            <DataGridTextColumn Header="Family Name (Revit)" Binding="{Binding FamilyName}" Width="*"/>
                            <DataGridTextColumn Header="Type Name" Binding="{Binding TypeName}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Rotation option -->
            <Border Style="{StaticResource Card}" Grid.Row="3">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Góc xoay:" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <RadioButton x:Name="RdoRotateFromCad" Content="Lấy từ Block CAD" Foreground="{StaticResource TextBrush}"
                                 FontSize="12" IsChecked="True" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <RadioButton x:Name="RdoRotateFixed" Content="Góc cố định:" Foreground="{StaticResource TextBrush}"
                                 FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtFixedRotation" Text="0" Width="50" Style="{StaticResource DarkTextBox}"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="°" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ FOOTER ═══ -->
        <DockPanel Grid.Row="2" Margin="0,16,0,0">
            <Button x:Name="BtnCancel" Content="Hủy" Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Right" Click="BtnCancel_Click" Margin="8,0,0,0"/>
            <Button x:Name="BtnRun" Content="▶ Đặt thiết bị" Style="{StaticResource PrimaryButton}"
                    Click="BtnRun_Click">
                <Button.Resources>
                    <SolidColorBrush x:Key="BlueBrush" Color="#FAB387"/>
                </Button.Resources>
            </Button>
        </DockPanel>
    </Grid>
</Window>
